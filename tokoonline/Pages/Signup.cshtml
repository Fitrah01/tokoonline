@page
@model tokoonline.Pages.SignupModel

<div class="container mt-5">

    <div class="card shadow p-5">

        <h1 class="mb-4 text-center">
            Sign Up
        </h1>

        <form method="post">

            <div class="mb-3">

                <label>
                    Nama
                </label>

                <input asp-for="Name"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label>
                    Email
                </label>

                <input asp-for="Email"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label>
                    Password
                </label>

                <input asp-for="Password"
                       type="password"
                       class="form-control" />

            </div>

            <button type="submit"
                    class="btn btn-dark w-100">

                Daftar

            </button>

        </form>

        <p class="text-danger mt-3">
            @Model.Message
        </p>

        <div class="text-center mt-3">

            <a href="/Login">
                Sudah punya akun?
            </a>

        </div>

    </div>

</div>