@page
@model LoginModel

<h2>Login</h2>

<form method="post">

    <input type="text" asp-for="Email" placeholder="Email" />
    <br />

    <input type="password" asp-for="Password" placeholder="Password" />
    <br />

    <button type="submit">Login</button>

</form>

<p style="color:red">@Model.ErrorMessage</p>